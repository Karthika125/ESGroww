generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id                      String   @id @default(cuid())
  hospitalName            String
  sectorCode              String   @default("HOSP") // HOSP, BLDG, MFGR, etc
  accountStatus           String   @default("Pending Verification") // Pending Verification, Active, Locked
  industry                String   @default("Healthcare")
  country                 String   @default("India")
  state                   String   @default("")
  builtUpArea             Float    @default(0) // in sqft
  numberOfBeds            Int      @default(0)
  numberOfEmployees       Int      @default(0) // FTE
  averageDailyOccupancy   Int      @default(0)
  operatingHours          Float    @default(24) // hours per day
  numberOfFloors          Int      @default(0)
  yearEstablished         Int      @default(2020)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users                   User[]
  electricityData         ElectricityData[]
  waterData               WaterData[]
  fuelData                FuelData[]
  wasteData               WasteData[]
  refrigerantData         RefrigerantData[]
  transportData           TransportData[]
  uploads                 Upload[]
  dataUploadBatches       DataUploadBatch[]
  esgScores               ESGScore[]
  governanceData          GovernanceData?
  assessmentHistory       AssessmentHistory[]
  validationResults       ValidationResult[]
  certificationScores     CertificationScore[]
  calculatedMetrics       CalculatedMetric[]
  emissionsSummary        EmissionsSummary[]
}

model User {
  id                       String   @id @default(cuid())

  fullName                 String

  email                    String   @unique

  password                 String

  role                     String   @default("hospital_admin")

  hospitalId               String

  emailVerified            Boolean  @default(false)

  emailVerificationToken   String?

  emailVerificationExpiry  DateTime?

  resetPasswordToken       String?

  resetPasswordExpiry      DateTime?

  failedLoginAttempts      Int      @default(0)

  accountLockedUntil       DateTime?

  lastLoginAt              DateTime?

  lastLoginIp              String?

  rememberMeEnabled        Boolean  @default(false)

  createdAt                DateTime @default(now())

  updatedAt                DateTime @updatedAt

  hospital Hospital @relation(fields: [hospitalId], references: [id])
}

/// Enterprise audit record for each accepted Excel ingestion (supports incremental + merge strategies).
model DataUploadBatch {
  id                    String   @id @default(cuid())
  hospitalId            String
  hospital              Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  category              String
  sourceFileName        String
  fileContentHash       String
  batchVersion          Int
  resolutionStrategy    String?
  distinctMonthCount    Int
  rowCount              Int
  monthKeysCsv          String?
  isSuperseded          Boolean  @default(false)
  supersededAt          DateTime?
  supersededByBatchId   String?
  createdAt             DateTime @default(now())

  electricityRows ElectricityData[]
  waterRows       WaterData[]
  fuelRows        FuelData[]
  wasteRows       WasteData[]
  refrigerantRows RefrigerantData[]
  transportRows   TransportData[]
  uploadRecord    Upload?

  @@index([hospitalId, category, createdAt])
  @@index([hospitalId, category, fileContentHash])
}

model ElectricityData {
  id               String   @id @default(cuid())
  hospitalId       String
  hospital         Hospital @relation(fields: [hospitalId], references: [id])
  month            String
  year             Int
  electricityKwh   Float    @default(0)
  renewableKwh     Float    @default(0)
  createdAt        DateTime @default(now())
  sourceBatchId    String?
  dataUploadBatch  DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year])
}

model WaterData {
  id              String   @id @default(cuid())
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  month           String
  year            Int
  waterKl         Float    @default(0)
  recycledWaterKl Float    @default(0)
  createdAt       DateTime @default(now())
  sourceBatchId   String?
  dataUploadBatch DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year])
}

model FuelData {
  id              String   @id @default(cuid())
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  month           String
  year            Int
  dgDieselLitres  Float    @default(0)
  createdAt       DateTime @default(now())
  sourceBatchId   String?
  dataUploadBatch DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year])
}

model WasteData {
  id                String   @id @default(cuid())
  hospitalId        String
  hospital          Hospital @relation(fields: [hospitalId], references: [id])
  month             String
  year              Int
  biomedicalWasteKg Float    @default(0)
  recyclableWasteKg Float    @default(0)
  landfillWasteKg   Float    @default(0)
  createdAt         DateTime @default(now())
  sourceBatchId     String?
  dataUploadBatch   DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year])
}

model RefrigerantData {
  id                String   @id @default(cuid())
  hospitalId        String
  hospital          Hospital @relation(fields: [hospitalId], references: [id])
  month             String
  year              Int
  refrigerantType   String
  refrigerantLeakKg Float    @default(0)
  createdAt         DateTime @default(now())
  sourceBatchId     String?
  dataUploadBatch   DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year, refrigerantType])
}

model TransportData {
  id                  String   @id @default(cuid())
  hospitalId          String
  hospital            Hospital @relation(fields: [hospitalId], references: [id])
  month               String
  year                Int
  ambulanceFuelLitres Float    @default(0)
  staffCommuteKm      Float    @default(0)
  createdAt           DateTime @default(now())
  sourceBatchId       String?
  dataUploadBatch     DataUploadBatch? @relation(fields: [sourceBatchId], references: [id], onDelete: SetNull)

  @@unique([hospitalId, month, year])
}

model GovernanceData {
  id                         String   @id @default(cuid())
  hospitalId                 String   @unique
  hospital                   Hospital @relation(fields: [hospitalId], references: [id])
  hasEsgPolicy               Boolean  @default(false)
  hasSustainabilityCommittee Boolean  @default(false)
  hasAuditReports            Boolean  @default(false)
  hasComplianceDocs          Boolean  @default(false)
  createdAt                  DateTime @default(now())
}

model Upload {
  id                 String   @id @default(cuid())
  hospitalId         String
  hospital           Hospital @relation(fields: [hospitalId], references: [id])
  category           String
  fileUrl            String
  month              String
  year               Int
  createdAt          DateTime @default(now())
  /// Same as `DataUploadBatch.id` when this row represents a batch ingestion.
  uploadBatchId      String?  @unique
  uploadBatch        DataUploadBatch? @relation(fields: [uploadBatchId], references: [id], onDelete: SetNull)
  /// Monotonic batch sequence for this hospital + category (audit).
  version            Int      @default(1)
  isReplaced         Boolean  @default(false)
  replacedAt         DateTime?
  uploadedAt         DateTime @default(now())
  rowCount           Int?
  fileContentHash    String?
  resolutionStrategy String?
  sourceFile         String?

  @@index([hospitalId, category, createdAt])
}

model ESGScore {
  id              String   @id @default(cuid())
  hospitalId      String
  hospital        Hospital @relation(fields: [hospitalId], references: [id])
  overallScore    Float
  energyScore     Float
  waterScore      Float
  wasteScore      Float
  governanceScore Float
  emissionsScore  Float
  createdAt       DateTime @default(now())
}

model AssessmentHistory {
  id                     String   @id @default(cuid())
  hospitalId             String
  createdAt              DateTime @default(now())
  completenessPct        Float?
  confidenceScore        Float?
  annualizedValues       Json?
  benchmarkScores        Json?
  certificationReadiness Json?
  gapAnalysis            Json?
  readinessStage         String?
  hospital               Hospital @relation(fields: [hospitalId], references: [id])

  @@index([hospitalId])
}

// NEW MODELS FOR BRD COMPLIANCE

model ValidationResult {
  id            String   @id @default(cuid())
  hospitalId    String
  hospital      Hospital @relation(fields: [hospitalId], references: [id])
  category      String // electricity, water, waste, fuel, refrigerant
  checkType     String // negative_value, missing_months, spike_detection, duplicate_entry, unit_consistency, cross_category
  status        String // Pass, Partial, Fail
  affectedMonth String? // month affected
  affectedYear  Int?
  notes         String?
  createdAt     DateTime @default(now())
}

model CertificationScore {
  id                     String   @id @default(cuid())
  hospitalId             String
  hospital               Hospital @relation(fields: [hospitalId], references: [id])
  certificationName      String // IGBC Healthcare, LEED, NABH, ISO 14001, WELL, BRSR, GRI, etc
  readinessPercent       Float
  statusLabel            String // Not Ready, Foundational, Certification Possible, Strong Readiness, Advanced
  majorGap               String?
  recommendedTimeline    String? // <3M, 3-6M, 6-12M, 12-18M, 12+M
  prerequisitesMetJson   Json? // Track which prerequisites are met
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model CalculatedMetric {
  id                 String   @id @default(cuid())
  hospitalId         String
  hospital           Hospital @relation(fields: [hospitalId], references: [id])
  metricName         String // Energy Intensity, Water Intensity, Renewable %, etc
  rawValue           Float?
  annualizedValue    Float?
  unit               String
  confidenceModifier Float    @default(1.0)
  benchmarkStatus    String? // Within, Slightly Below, Above, Insufficient Data
  createdAt          DateTime @default(now())
}

model EmissionsSummary {
  id         String   @id @default(cuid())
  hospitalId String
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
  scope      String // Scope 1, Scope 2, Scope 3
  source     String // Diesel, PNG, Electricity, Waste, etc
  kgCO2e     Float
  tCO2e      Float
  factorUsed String?
  createdAt  DateTime @default(now())
}

model CertificationApplicability {
  id                  String @id @default(cuid())
  sectorCode          String // HOSP, BLDG, MFGR, etc
  certificationName   String
  importanceLevel     String // Mandatory, Highly Recommended, Optional
  @@unique([sectorCode, certificationName])
}

model BenchmarkMaster {
  id             String @id @default(cuid())
  sectorCode     String
  metricName     String // Energy Intensity, Water Intensity, etc
  efficientMax   Float
  acceptableMin  Float
  acceptableMax  Float
  unit           String
  @@unique([sectorCode, metricName])
}

model EmissionFactor {
  id              String   @id @default(cuid())
  sourceType      String // Diesel, PNG, Electricity, Waste, etc
  region          String   @default("India")
  factorValue     Float
  unit            String // kgCO2e/unit
  overrideAllowed Boolean  @default(true)
  createdAt       DateTime @default(now())
  @@unique([sourceType, region])
}

model ConfidenceThreshold {
  id              String @id @default(cuid())
  monthsMin       Int
  monthsMax       Int
  modifier        Float
  confidenceLabel String // High, Medium, Low, Insufficient
  @@unique([monthsMin, monthsMax])
}
